# Server
HTTP_PORT=8080
HTTP_TIMEOUT=4s
ENV=local

# PostgreSQL (Matches official Docker image env names)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret
POSTGRES_DB=subs_db

# App Database Connection (Used by config/env.Parse)
DB_HOST=localhost
DB_PORT=5432

# Goose
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:secret@localhost:5432/subs_db
GOOSE_MIGRATION_DIR=./migrations
# GOOSE_TABLE=custom.goose_migrations